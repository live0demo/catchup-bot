# --- Telegram ---
# Get this from @BotFather. Required.
BOT_TOKEN=123456:replace-me

# --- Branding (in-app text only; BotFather owns @username, profile name, bio) ---
BOT_DISPLAY_NAME=Catchup Bot
BOT_USERNAME_HINT=@your_bot
BOT_SHORT_DESCRIPTION=Group catch-up summaries and reminders.
BOT_BRAND_EMOJI=🦉

# --- Storage ---
# SQLite path. For Docker the default volume mount is ./data.
DATABASE_URL=sqlite:///./data/bot.db

# --- Behavior ---
# How many days of cached group messages to keep.
MESSAGE_RETENTION_DAYS=14
# Default timezone used when a user has not set their own (IANA name).
DEFAULT_TIMEZONE=UTC
# Where summaries should be delivered when not specified: private | group | ask
DEFAULT_DELIVERY_MODE=private
# Logging level
LOG_LEVEL=INFO

# --- Optional LLM (any OpenAI-compatible Chat Completions endpoint) ---
# Leave LLM_API_KEY empty to use the built-in local summarizer only.
# Free-tier providers (no card needed) — pick ONE block and uncomment:
#
# Google Gemini (best Vietnamese, 1500 req/day free):
#   LLM_API_KEY=<from https://aistudio.google.com/apikey>
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.0-flash
#
# Groq (very fast, 14400 req/day free):
#   LLM_API_KEY=<from https://console.groq.com/keys>
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# OpenRouter (mix of free models):
#   LLM_API_KEY=<from https://openrouter.ai/keys>
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Force LLM responses into a specific language (e.g. "Vietnamese", "English").
# "auto" = reply in the dominant language of the input. Only affects LLM mode.
SUMMARY_LANGUAGE=auto

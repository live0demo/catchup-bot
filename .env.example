# --- Telegram ---
# Get this from @BotFather. Required.
BOT_TOKEN=123456:replace-me

# --- Branding (in-app text only; BotFather owns @username, profile name, bio) ---
BOT_DISPLAY_NAME=Catchup Bot
BOT_USERNAME_HINT=@your_bot
BOT_SHORT_DESCRIPTION=Group catch-up summaries and reminders.
BOT_BRAND_EMOJI=🦉

# --- Storage ---
# SQLite path. For Docker the default volume mount is ./data.
DATABASE_URL=sqlite:///./data/bot.db

# --- Behavior ---
# How many days of cached group messages to keep.
MESSAGE_RETENTION_DAYS=14
# Default timezone used when a user has not set their own (IANA name).
DEFAULT_TIMEZONE=UTC
# Where summaries should be delivered when not specified: private | group | ask
DEFAULT_DELIVERY_MODE=private
# Logging level
LOG_LEVEL=INFO

# --- Optional LLM (OpenAI-compatible Chat Completions) ---
# Leave LLM_API_KEY empty to use the built-in local summarizer only.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
